# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ========================================
# DATABASE
# ========================================
MONGODB_URI=mongodb://localhost:27017/chatbot_db
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/chatbot_db

# ========================================
# JWT AUTHENTICATION
# ========================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_EXPIRES_IN=24h

# ========================================
# AI PROVIDER (openai | gemini)
# ========================================
LLM_PROVIDER=openai

# OpenAI / Custom compatible API (e.g. OpenRouter)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1      # Set to use OpenRouter or other OpenAI-compatible endpoints
OPENAI_MODEL=gpt-4o-mini                          # Or your OpenRouter model e.g., google/gemini-flash-1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small     # Or your OpenRouter embedding model

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ========================================
# VECTOR DATABASE
# ========================================
# ChromaDB (local default)
VECTOR_DB_PROVIDER=chroma
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=restaurant_knowledge

# Pinecone (cloud option)
# VECTOR_DB_PROVIDER=pinecone
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_ENVIRONMENT=us-east-1-aws
# PINECONE_INDEX=restaurant-chatbot

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=20

# ========================================
# FILE UPLOADS
# ========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ========================================
# RESTAURANT CONFIGURATION
# ========================================
RESTAURANT_NAME=Kalai Restaurant
RESTAURANT_LOCATION=123 Main Street, City, State 12345
RESTAURANT_PHONE=+1 (555) 123-4567
RESTAURANT_EMAIL=info@kalairestaurant.com

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_DIR=./logs

# ========================================
# ADMIN CREDENTIALS (Initial Setup)
# ========================================
ADMIN_EMAIL=admin@kalairestaurant.com
ADMIN_PASSWORD=Admin@123456
ADMIN_USERNAME=admin
